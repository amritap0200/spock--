{
  "manifest_version": 3,
  "name": "Verifyy - Deepfake Detector",
  "version": "1.1.0",
  "description": "Real-time multimodal deepfake detection. Upload a video or analyze any page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Verifyy"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}